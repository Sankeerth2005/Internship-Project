# =========================================================================
#                       LOCALINK - ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy this file to a new file named '.env' and populate the actual keys.
#
# This file serves as the single source of truth for both:
# 1. Frontend Web (Angular) & Mobile (Flutter)
# 2. Backend API (.NET Web API)
# =========================================================================

# -------------------------------------------------------------------------
# 1. CORE API & PUBLIC CLIENT SETTINGS (Used by Web/Mobile Frontend)
# -------------------------------------------------------------------------
# The API base URL that the mobile app & website will query to reach the backend
BACKEND_API_URL=http://localhost:5138/api

# The Google reCAPTCHA Site Key used to render client-side captcha checkboxes
RECAPTCHA_SITE_KEY=6Ld0TkQtAAAAAFifZR_AuJbSZzWnCb-j7Rk2NWsT

# -------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (Used by Backend API)
# -------------------------------------------------------------------------
# Connection String for your SQL Server Express instance
DB_CONNECTION_STRING=Data Source=LAPTOP-9NFGOH5A\SQLEXPRESS;Database=LocalinkDb;Integrated Security=True;Persist Security Info=False;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Application Name="SQL Server Management Studio";Command Timeout=0
# -------------------------------------------------------------------------
# 3. SECURITY & JWT CONFIGURATION (Used by Backend API)
# -------------------------------------------------------------------------
# The secret key used to sign JWT authorization tokens (minimum 256-bit / 32 characters)
JWT_SECRET_KEY=9xWz5B8vE1hYp3q7rD2gF4sJ6kL8nP0mQ9aS8dF7gH6jK5l4zX3c2vB1nM0pO9iU
JWT_ISSUER=LocalinkAPI
