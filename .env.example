# -------------------------------------------------------------------------
# 4. CAPTCHA SERVER CONFIGURATION (Used by Backend API)
# -------------------------------------------------------------------------
# Google reCAPTCHA secret key used by backend to verify token legitimacy
CAPTCHA_SECRET_KEY=6Ld0TkQtAAAAAK95F1Z_YOW-KVZfwaxND3kyB0EI

# -------------------------------------------------------------------------
# 5. EXTERNAL API CONFIGURATIONS (Used by Backend API)
# -------------------------------------------------------------------------

# CountryStateCity API - For dynamic Country/State/City selections in signups
# Base URL: https://api.countrystatecity.in/v1
COUNTRY_CSC_API_KEY=your_country_csc_api_key_here

# Geoapify API - For pincode checks, address auto-completes and maps
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Groq Cloud API - Used to run AI-based "Improve with AI" review enhancements
GROQ_API_KEY=your_groq_api_key_here

